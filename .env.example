# ─── Telegram Bot ────────────────────────────────────────────────
# Obtén tu token de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui

# ─── Mistral AI ──────────────────────────────────────────────────
# Obtén tu API key en https://console.mistral.ai/
MISTRAL_API_KEY=tu_api_key_aqui
MISTRAL_MODEL=mistral-large-latest

# ─── Web Search (Tavily) ─────────────────────────────────────────
# Obtén tu API key en https://tavily.com/#api
TAVILY_API_KEY=tu_api_key_aqui
TAVILY_SEARCH_DEPTH=advanced
MAX_SEARCH_RESULTS=8

# ─── Bot Settings ────────────────────────────────────────────────
BOT_USERNAME=KynariBot
BOT_LANGUAGE=es

# ─── Webhook (opcional, para producción en Render) ──────────────
USE_WEBHOOK=false
WEBHOOK_URL=https://tudominio.com
# PORT se establece automáticamente en Render

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
